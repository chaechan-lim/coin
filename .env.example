# Exchange
EXCHANGE_NAME=bithumb
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_RATE_LIMIT_PER_SEC=8

# Trading
TRADING_MODE=paper
TRADING_EVALUATION_INTERVAL_SEC=300
TRADING_INITIAL_BALANCE_KRW=500000
TRADING_MIN_TRADE_INTERVAL_SEC=3600
TRADING_COOLDOWN_AFTER_BUY_SEC=1800
TRADING_DAILY_BUY_LIMIT=20
TRADING_MAX_DAILY_COIN_BUYS=3
TRADING_MIN_COMBINED_CONFIDENCE=0.50

# Rotation
TRADING_ROTATION_ENABLED=true
TRADING_SURGE_THRESHOLD=3.0
TRADING_ROTATION_COOLDOWN_SEC=7200

# Risk
RISK_MAX_SINGLE_COIN_PCT=0.40
RISK_MAX_DRAWDOWN_PCT=0.10
RISK_DAILY_LOSS_LIMIT_PCT=0.03
RISK_MAX_TRADE_SIZE_PCT=0.20
RISK_MAX_OPEN_ORDERS=20

# Database
DB_URL=postgresql+asyncpg://coin:coin@localhost:5432/coin_trading
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Notification (optional)
NOTIFY_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# App
APP_LOG_LEVEL=INFO
